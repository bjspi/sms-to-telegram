root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_style = space
indent_size = 4
max_line_length = 120

[*.{xml,yml,yaml,toml,json}]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.bat]
end_of_line = crlf
